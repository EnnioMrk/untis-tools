// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// Enums

enum Plan {
  BASIC
  STANDARD
  PREMIUM
}

enum PlanSource {
  NONE
  SUBSCRIPTION
  TRIAL
  BONUS
}

enum ShopTheme {
  DEFAULT
  MIDNIGHT
  SUNSET
  FOREST
  AURORA
}

enum WidgetType {
  KPI_7DAYS
  KPI_14DAYS
  KPI_30DAYS
  KPI_ALLTIME
  ABSENCE_BAR
  ABSENCE_TREND
  SUBJECT_BREAKDOWN
  ABSENCE_RECOMMENDER
  ABSENCE_RATE
  TOTAL_ABSENCE_BAR
}

// User Model

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  emailVerified DateTime?
  image         String?
  plan          Plan       @default(BASIC)
  planSource    PlanSource @default(NONE)
  isAdmin       Boolean    @default(false)
  trialEndsAt   DateTime?
  accessEndsAt  DateTime?
  referralBonusMonths Int  @default(0)
  activeTheme   ShopTheme @default(DEFAULT)
  
  // Paddle Integration
  paddleCustomerId     String?
  paddleSubscriptionId String?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  accounts        Account[]
  sessions        Session[]
  untisConnection UntisConnection?
  userStats       UserStats?
  widgets         Widget[]
  themePurchases  ThemePurchase[]
  ownedReferralCode ReferralCode? @relation("UserOwnedReferralCode")
  redeemedReferral  ReferralRedemption? @relation("RedeemedReferral")
  adminCreatedReferralCodes ReferralCode[] @relation("AdminCreatedReferralCodes")
  adminCreatedCouponCodes CouponCode[] @relation("AdminCreatedCouponCodes")

  @@index([plan])
  @@index([isAdmin])
}

// Auth.js v5 Models

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([identifier, token])
}

// UntisConnection Model

model UntisConnection {
  id        String    @id @default(cuid())
  userId    String    @unique
  serverUrl String
  school    String
  username  String
  secret    String
  isActive  Boolean   @default(true)
  dataStartDate DateTime?
  lastSyncAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isActive])
}

// UserStats Model

model UserStats {
  id               String   @id @default(cuid())
  userId           String   @unique
  absences7Days    Int      @default(0)
  absences14Days   Int      @default(0)
  absences30Days   Int      @default(0)
  trend7Days       Json?
  trend14Days      Json?
  trend30Days      Json?
  subjectBreakdown Json
  dailyTrend       Json
  lastCalculated   DateTime @default(now())
  absenceRate      Float    @default(0)
  totalRealLessons Int      @default(0)
  totalAbsences    Int      @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([lastCalculated])
}

// Widget Model

model Widget {
  id         String     @id @default(cuid())
  userId     String
  type       WidgetType
  layoutData Json
  config     Json?
  order      Int        @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
}

model ThemePurchase {
  id                  String    @id @default(cuid())
  userId              String
  theme               ShopTheme
  priceCents          Int?
  paddleTransactionId String?   @unique
  purchasedAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, theme])
  @@index([userId])
}

model ReferralCode {
  id              String   @id @default(cuid())
  code            String   @unique
  label           String?
  isActive        Boolean  @default(true)
  maxRedemptions  Int?
  ownerUserId     String?  @unique
  createdByAdminId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner          User?                @relation("UserOwnedReferralCode", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdByAdmin User?                @relation("AdminCreatedReferralCodes", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  redemptions    ReferralRedemption[]

  @@index([isActive])
  @@index([createdByAdminId])
}

model ReferralRedemption {
  id             String   @id @default(cuid())
  codeId         String
  referredUserId String   @unique
  redeemedAt     DateTime @default(now())
  rewardGrantedAt DateTime?

  code         ReferralCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  referredUser User         @relation("RedeemedReferral", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([codeId])
  @@index([rewardGrantedAt])
}

model CouponCode {
  id               String   @id @default(cuid())
  code             String   @unique
  description      String?
  discountPercent  Int?
  freeMonths       Int      @default(0)
  isActive         Boolean  @default(true)
  maxRedemptions   Int?
  expiresAt        DateTime?
  createdByAdminId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdByAdmin User @relation("AdminCreatedCouponCodes", fields: [createdByAdminId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([createdByAdminId])
}
